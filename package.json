{
  "name": "hakoniwa-term",
  "version": "0.0.9",
  "description": "A robust, pluggable retro terminal engine for React, powered by CSS Modules and Async Generators.",
  "author": "koji <baxin1919@gmail.com>",
  "homepage": "https://github.com/koji/hakoniwa-term",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/koji/hakoniwa-term.git"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./dist/index.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "lucide-react": "^0.470.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "8.1.3",
    "vite-plugin-dts": "^4.4.0"
  },
  "keywords": [
    "react",
    "terminal",
    "cli-ui",
    "css-modules",
    "async-generator",
    "typescript",
    "vite"
  ],
  "license": "MIT",
  "publishConfig": {
